{
  "name": "bulma-resume-template",
  "version": "1.0.0",
  "description": "💼 Free resume page template with bulma css",
  "main": "index.js",
  "scripts": {
    "dev": "cross-env NODE_ENV=development webpack serve --hot --open",
    "build": "rimraf ./dist && rimraf index.* light* dracula* && cross-env NODE_ENV=production webpack --color && cp -R dist/* .",
    "dist": "npm run build",
    "publish-demo": "node ./publish-demo.js",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mazipan/bulma-resume-template.git"
  },
  "keywords": [
    "bulma",
    "css-template",
    "resume-template",
    "resume-website"
  ],
  "author": "Irfan Maulana <github.com/mazipan/>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/mazipan/bulma-resume-template/issues"
  },
  "homepage": "https://github.com/mazipan/bulma-resume-template#readme",
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@babel/preset-env": "^7.26.0",
    "babel-loader": "^9.2.1",
    "compression-webpack-plugin": "^12.0.0",
    "cross-env": "^7.0.3",
    "css-loader": "^7.1.2",
    "css-minimizer-webpack-plugin": "^8.0.0",
    "glob": "^11.0.0",
    "html-webpack-plugin": "^5.6.3",
    "mini-css-extract-plugin": "^2.9.2",
    "purgecss-webpack-plugin": "^6.0.0",
    "rimraf": "^6.0.1",
    "sass": "^1.83.0",
    "sass-loader": "^16.0.4",
    "terser-webpack-plugin": "^5.3.11",
    "webpack": "^5.97.1",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.0"
  },
  "dependencies": {
    "bulma": "0.9.4",
    "bulma-dracula": "^1.0.3",
    "gh-pages": "^6.2.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^2.5.2"
  }
}
